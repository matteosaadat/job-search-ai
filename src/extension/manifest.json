{
  "manifest_version": 3,
  "name": "Job Hunt Capture",
  "version": "1.1",
  "description": "Capture job listings from any page into your local Job Hunt pipeline",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["http://localhost:8001/*", "<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Capture Job"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
